# ============================================================
# .env.example — Template de variáveis de ambiente
# ============================================================
#
# COMO USAR:
#   cp .env.example .env.local
#   Preencha os valores em .env.local e NUNCA o commite.
#
# Variáveis com prefixo NEXT_PUBLIC_ são expostas ao browser.
# Variáveis sem prefixo são privadas do servidor.
#
# Após alterar variáveis, reinicie o servidor: npm run dev
# ============================================================

# ID do seu blog no WISP CMS (https://wisp.blog → Settings → Blog ID)
NEXT_PUBLIC_BLOG_ID=00000000-0000-0000-0000-000000000000

# URL base do site em produção (ex.: https://seu-dominio.vercel.app)
NEXT_PUBLIC_BASE_URL=https://seu-dominio.vercel.app

# Título exibido na navbar e meta tags (recomenda-se ≤ 60 chars)
NEXT_PUBLIC_BLOG_DISPLAY_NAME=PsicologaEmOutraDimensão

# Descrição do site para SEO / meta description (recomenda-se ≤ 160 chars)
NEXT_PUBLIC_BLOG_DESCRIPTION=Blog pessoal

# ── Secrets do servidor (privados — NUNCA exponha estes valores) ──────────────
#
# Para gerar um valor seguro (32 bytes = 64 chars hex):
#   openssl rand -hex 32
# ou (Node.js):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Em produção/CI: armazene como secrets no ambiente
# (Vercel → Project Settings → Environment Variables → Secret).
# Deixe os campos abaixo VAZIOS neste arquivo.
#
# OG_IMAGE_SECRET: chave HMAC para assinar URLs de Open Graph images.
OG_IMAGE_SECRET=

# REVALIDATION_SECRET: segredo para o endpoint /api/revalidate.
REVALIDATION_SECRET=

# FREEPIK_API_KEY: chave para a API de geração de ícones AI (https://docs.freepik.com)
FREEPIK_API_KEY=
